---
interface Props {
  title: string;
  persona?: string;
}
const { title, persona } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --primary:       #FF5623;
      --primary-hover: #CC451C;
      --dark:          #1A0D32;
      --dark-deep:     #0A0614;
      --gray:          #5a5668;
      --light:         #F5F5F5;
      --light-alt:     #E8E8E8;
      --card-bg:       #D1CFD6;
      --border:        #D9D9D9;
      --gradient:      linear-gradient(135deg, #1A0D32 0%, #0A0614 100%);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      height: 100%;
      overflow: hidden;
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: white;
      color: var(--dark);
    }

    .slide-container {
      height: 100vh;
      width: 100vw;
      overflow: hidden;
      position: relative;
    }

    .slides {
      display: flex;
      flex-direction: column;
      transition: transform 0.8s cubic-bezier(0.77, 0, 0.175, 1);
    }

    section {
      height: 100vh;
      padding: 100px 60px;
      display: flex;
      align-items: center;
      position: relative;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    h1 { font-size: 56px; font-weight: 700; line-height: 1.1; }
    h2 { font-size: 48px; font-weight: 700; margin-bottom: 20px; }
    h3 { font-size: 32px; font-weight: 700; }
    p  { font-size: 18px; color: var(--gray); max-width: 900px; }

    .highlight { color: var(--primary); font-weight: 700; }
    .section-light { background: var(--light); }

    .cta { background: var(--gradient); color: white; }
    .cta p { color: rgba(255,255,255,0.7); }
    .cta h1, .cta h2 { color: white; }

    /* ── Fixed chrome ── */
    .deck-logo {
      position: fixed; top: 30px; left: 50px;
      z-index: 3000;
      display: flex; align-items: center; gap: 10px;
    }
    .deck-logo-text {
      font-weight: 800; letter-spacing: 3px; font-size: 18px;
      font-family: 'Plus Jakarta Sans', sans-serif; color: var(--dark);
    }

    .deck-back {
      position: fixed; top: 32px; right: 50px;
      font-size: 13px; color: var(--gray); text-decoration: none;
      z-index: 3000; letter-spacing: 0.5px; opacity: 0.6;
      transition: opacity 0.2s, color 0.2s;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .deck-back:hover { opacity: 1; color: var(--dark); }

    .deck-persona {
      position: fixed; bottom: 30px; left: 50px;
      font-size: 11px; color: var(--gray); z-index: 3000;
      letter-spacing: 2px; text-transform: uppercase; opacity: 0.45;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .deck-counter {
      position: fixed; bottom: 30px; right: 50px;
      font-size: 13px; color: var(--gray); z-index: 3000;
      letter-spacing: 1px; font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* ── Speaker notes toggle ── */
    .notes-btn {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
      font-size: 10px; font-weight: 600; letter-spacing: 2.5px;
      text-transform: uppercase; color: var(--gray); opacity: 0.32;
      z-index: 3000; cursor: pointer; user-select: none;
      transition: opacity 0.2s, color 0.2s;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .notes-btn:hover { opacity: 0.65; }
    .notes-btn.on { color: var(--primary); opacity: 1; }

    /* ── Speaker notes panel ── */
    aside.notes {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0;
      background: rgba(10,6,20,0.97);
      backdrop-filter: blur(6px);
      border-top: 2px solid var(--primary);
      padding: 16px 60px 22px;
      max-height: 220px; overflow-y: auto;
      z-index: 2000;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    aside.notes.visible { display: block; }

    .notes-say {
      font-size: 15px; line-height: 1.7;
      color: rgba(255,255,255,0.9);
      margin-bottom: 6px;
    }
    .notes-dir {
      font-size: 12px; font-style: italic;
      color: rgba(255,255,255,0.36);
      margin-bottom: 10px;
    }

    /* ── Step reveal animation ── */
    .step-reveal {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .step-reveal.step-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body>

  <div class="deck-logo">
    <img src="/logos/stakater-logo.png" alt="Stakater" style="height:32px;" />
    <span class="deck-logo-text">STAKATER</span>
  </div>
  <a href="/" class="deck-back">← All Decks</a>
  {persona && <div class="deck-persona">{persona}</div>}
  <div class="deck-counter" id="counter"></div>
  <div class="notes-btn" id="notes-btn">N · Notes</div>

  <div class="slide-container">
    <div class="slides" id="slides">
      <slot />
    </div>
  </div>

  <script>
    const slides   = document.getElementById('slides');
    const sections = document.querySelectorAll('section');
    const counter  = document.getElementById('counter');
    const notesBtn = document.getElementById('notes-btn');
    let currentIndex = 0;
    let scrollLocked = false;
    let notesOn = false;

    function syncNotes() {
      document.querySelectorAll('aside.notes').forEach(n => n.classList.remove('visible'));
      if (notesOn) {
        const n = sections[currentIndex]?.querySelector('aside.notes');
        if (n) n.classList.add('visible');
      }
      notesBtn?.classList.toggle('on', notesOn);
    }

    // Per-slide step tracking
    const slideSteps = {};

    function revealSteps(sectionIndex, stepNum) {
      sections[sectionIndex].querySelectorAll('[data-step]').forEach(el => {
        el.classList.toggle('step-visible', parseInt(el.dataset.step) <= stepNum);
      });
    }

    function goToSlide(index) {
      currentIndex = Math.max(0, Math.min(index, sections.length - 1));
      slides.style.transform = `translateY(-${currentIndex * 100}vh)`;
      counter.textContent = `${currentIndex + 1} / ${sections.length}`;
      // Restore any steps already revealed on re-entry
      revealSteps(currentIndex, slideSteps[currentIndex] || 0);
      syncNotes();
    }

    function tryAdvance(direction) {
      const max = parseInt(sections[currentIndex]?.dataset.steps || 0);
      const cur = slideSteps[currentIndex] || 0;
      if (direction > 0 && cur < max) {
        slideSteps[currentIndex] = cur + 1;
        revealSteps(currentIndex, slideSteps[currentIndex]);
        return;
      }
      if (direction < 0 && cur > 0) {
        slideSteps[currentIndex] = cur - 1;
        revealSteps(currentIndex, slideSteps[currentIndex]);
        return;
      }
      goToSlide(currentIndex + direction);
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') tryAdvance(1);
      if (e.key === 'ArrowUp'   || e.key === 'ArrowLeft')  tryAdvance(-1);
      if (e.key === 'n' || e.key === 'N') { notesOn = !notesOn; syncNotes(); }
    });

    document.addEventListener('wheel', e => {
      e.preventDefault();
      if (scrollLocked) return;
      scrollLocked = true;
      if (e.deltaY > 0) tryAdvance(1);
      else              tryAdvance(-1);
      setTimeout(() => { scrollLocked = false; }, 900);
    }, { passive: false });

    let touchStartY = 0;
    document.addEventListener('touchstart', e => { touchStartY = e.touches[0].clientY; });
    document.addEventListener('touchend', e => {
      const diff = touchStartY - e.changedTouches[0].clientY;
      if (Math.abs(diff) > 50) {
        if (diff > 0) tryAdvance(1);
        else          tryAdvance(-1);
      }
    });

    notesBtn?.addEventListener('click', () => { notesOn = !notesOn; syncNotes(); });

    goToSlide(0);
  </script>

</body>
</html>
