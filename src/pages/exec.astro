---
import Deck from '../layouts/Deck.astro';
import AboutStakater from '../components/slides/AboutStakater.astro';
---
<Deck title="Stakater | Executive Overview" persona="VP / Regional Director">

  <!-- 1. About Stakater -->
  <AboutStakater />

  <!-- 2. The Problem -->
  <section class="section-light">
    <div class="container" style="max-width:900px;">
      <h1>
        Every Stalled OpenShift Account Is a<br/>
        <span class="highlight">Missed ARR Opportunity.</span>
      </h1>
      <br/><br/>
      <p style="font-size:24px; line-height:1.7; color:#2F3542; max-width:100%;">
        Subscription sold. Cluster live.<br/>
        Nodes flat. No portfolio adoption.<br/>
        Renewal risk increasing.
      </p>
      <br/>
      <p style="font-size:24px; line-height:1.7; color:#2F3542; max-width:100%;">
        The gap between installed and expanding<br/>
        is where ARR is being left on the table.
      </p>
      <br/><br/>
      <h2>
        Nobody in your current partner mix <span class="highlight">owns this gap.</span>
      </h2>
    </div>
  </section>

  <!-- 3. What We Do -->
  <section>
    <div class="container">
      <h1 style="text-align:center;">
        We Convert <span class="highlight">Stalled Accounts</span> Into Growing Platforms.
      </h1>
      <br/><br/><br/>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:60px; text-align:center;">

        <div>
          <div style="font-size:38px; font-weight:800; color:#E00000; margin-bottom:16px;">More Nodes</div>
          <p style="font-size:18px; color:#374151; line-height:1.6;">
            More workloads on OpenShift. ARR grows as the platform scales.
          </p>
        </div>

        <div>
          <div style="font-size:38px; font-weight:800; color:#E00000; margin-bottom:16px;">More Products</div>
          <p style="font-size:18px; color:#374151; line-height:1.6;">
            ODF, ACM, ACS, AMQ. We create the conditions for portfolio pull-through.
          </p>
        </div>

        <div>
          <div style="font-size:38px; font-weight:800; color:#E00000; margin-bottom:16px;">More Clusters</div>
          <p style="font-size:18px; color:#374151; line-height:1.6;">
            From one cluster to org-wide OpenShift standard. Multi-year, multi-site expansion.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. Proof -->
  <section class="section-light">
    <div class="container">
      <h1 style="text-align:center;">
        Three Accounts. <span class="highlight">Same Story.</span>
      </h1>
      <br/><br/><br/>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:60px; text-align:center;">

        <div>
          <div style="margin-bottom:18px;">
            <img src="/logos/atg.png" alt="ATG" style="height:44px;">
          </div>
          <div style="font-size:40px; font-weight:800; color:#E00000; margin-bottom:10px;">7 Years</div>
          <p style="font-size:18px; color:#374151;">Sustained node growth. OpenShift became the strategic platform.</p>
        </div>

        <div>
          <div style="margin-bottom:18px;">
            <img src="/logos/csn.png" alt="CSN" style="height:44px;">
          </div>
          <div style="font-size:40px; font-weight:800; color:#E00000; margin-bottom:10px;">ODF + Nodes</div>
          <p style="font-size:18px; color:#374151;">Post-implementation gap closed. Storage and platform expansion followed.</p>
        </div>

        <div>
          <div style="margin-bottom:18px;">
            <img src="/logos/rs.png" alt="Region Skåne" style="height:44px;">
          </div>
          <div style="font-size:40px; font-weight:800; color:#E00000; margin-bottom:10px;">1 → Many</div>
          <p style="font-size:18px; color:#374151;">Single cluster to org-wide standard. New products adopted along the way.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 5. The Ask -->
  <section class="cta">
    <div class="container" style="text-align:center;">
      <h1>
        One Session.
      </h1>
      <br/><br/>
      <h2>
        We map 3–5 accounts from your portfolio<br/>
        against our lifecycle model.
      </h2>
      <br/>
      <h2>
        You see exactly where the ARR opportunity is.
      </h2>
      <br/><br/><br/>
      <h1 style="font-weight:900;">
        No Cost. No Commitment. Just the Map.
      </h1>
    </div>
  </section>

</Deck>
