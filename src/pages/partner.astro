---
import Deck from '../layouts/Deck.astro';
import AboutStakater from '../components/slides/AboutStakater.astro';
import Partnership from '../components/slides/Partnership.astro';
---
<Deck title="Stakater | Partner Sales Executive" persona="Partner Sales Executive">

  <!-- 1. Hero -->
  <section>
    <div class="container" style="text-align:center;">
      <h1>
        Your Ecosystem Needs a<br/>
        <span class="highlight">Platform Growth Partner.</span>
      </h1>
      <br/><br/>
      <h2 style="color:#6B7280; font-weight:500; font-size:32px;">
        How Stakater drives co-sell pipeline through lifecycle ownership.
      </h2>
    </div>
  </section>

  <!-- 2. About Stakater -->
  <AboutStakater />

  <!-- 3. Partnership -->
  <Partnership />

  <!-- 3. The Partner Gap -->
  <section>
    <div class="container">
      <h1>
        Delivery Partners Close Projects.<br/>
        <span class="highlight">Nobody Owns What Comes Next.</span>
      </h1>
      <br/><br/>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start;">

        <div style="padding:30px; background:#F4F6F9; border-radius:8px;">
          <h3 style="color:#6B7280; margin-bottom:16px; font-size:20px;">Typical Partner Motion</h3>
          <p style="font-size:19px; line-height:1.7; color:#374151;">
            Project scoped and staffed.<br/>
            Implementation delivered.<br/>
            Partner disengages.<br/>
            Expansion opportunities go unregistered.
          </p>
        </div>

        <div style="padding:30px; border-left:4px solid #E00000;">
          <h3 style="margin-bottom:16px; font-size:20px;">What Creates Pipeline</h3>
          <p style="font-size:19px; line-height:1.7; color:#1F2937;">
            Long-term lifecycle ownership.<br/>
            Platform growth creates new deal moments.<br/>
            Every expansion is a registerable opportunity.<br/>
            Portfolio adoption = new SKUs = new revenue.
          </p>
        </div>

      </div>
      <br/><br/>
      <h2>
        Stakater is the lifecycle partner that keeps <span class="highlight">pipeline alive.</span>
      </h2>
    </div>
  </section>

  <!-- 4. Co-Sell Motion -->
  <section class="section-light">
    <div class="container">
      <h1 style="text-align:center;">
        The <span class="highlight">Co-Sell Motion</span>
      </h1>
      <br/><br/><br/>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:50px; text-align:center;">

        <div>
          <h2 style="color:#E00000; font-size:32px; margin-bottom:16px;">Source</h2>
          <p style="font-size:18px; color:#374151; line-height:1.6;">
            We identify expansion opportunities inside existing Red Hat accounts through lifecycle engagement.
          </p>
        </div>

        <div>
          <h2 style="color:#E00000; font-size:32px; margin-bottom:16px;">Influence</h2>
          <p style="font-size:18px; color:#374151; line-height:1.6;">
            We create technical demand — workload acceleration, portfolio readiness, governance alignment.
          </p>
        </div>

        <div>
          <h2 style="color:#E00000; font-size:32px; margin-bottom:16px;">Register</h2>
          <p style="font-size:18px; color:#374151; line-height:1.6;">
            We co-register expansion deals — nodes, additional clusters, new Red Hat products.
          </p>
        </div>

      </div>
      <br/><br/><br/>
      <h2 style="text-align:center;">
        You set the commercial motion. We bring <span class="highlight">technical depth and account continuity.</span>
      </h2>
    </div>
  </section>

  <!-- 5. Partner Credentials -->
  <section>
    <div class="container">
      <h1 style="text-align:center;">
        A <span class="highlight">Credentialed</span> Co-Sell Partner
      </h1>
      <br/><br/><br/>
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:40px; text-align:center;">

        <div>
          <h2 style="color:#E00000; font-size:26px; margin-bottom:14px;">CCSP</h2>
          <p style="font-size:17px; color:#374151;">Certified Cloud & Service Provider. Lifecycle management and managed OpenShift delivery.</p>
        </div>

        <div>
          <h2 style="color:#E00000; font-size:26px; margin-bottom:14px;">Specialized</h2>
          <p style="font-size:17px; color:#374151;">Container Management specialization. Recognized technical depth in OpenShift platforms.</p>
        </div>

        <div>
          <h2 style="color:#E00000; font-size:26px; margin-bottom:14px;">Certified Engineers</h2>
          <p style="font-size:17px; color:#374151;">RHCEs and OpenShift specialists. Platform-native engineers, not generalists.</p>
        </div>

        <div>
          <h2 style="color:#E00000; font-size:26px; margin-bottom:14px;">8+ Years</h2>
          <p style="font-size:17px; color:#374151;">In the Red Hat ecosystem. Progressive partner tier. Deep institutional alignment.</p>
        </div>

      </div>
      <br/><br/><br/>
      <h2 style="text-align:center;">
        Not a new partner. A <span class="highlight">proven ecosystem player.</span>
      </h2>
    </div>
  </section>

  <!-- 6. Joint Pipeline Play -->
  <section class="section-light">
    <div class="container">
      <h1 style="text-align:center;">
        The <span class="highlight">Joint Pipeline</span> Play
      </h1>
      <br/><br/>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:50px;">

        <div style="padding:36px; background:white; border-radius:12px; box-shadow:0 8px 30px rgba(0,0,0,0.05);">
          <h3 style="margin-bottom:20px; font-size:22px;">Long-Term Account Continuity</h3>
          <p style="font-size:18px; color:#374151; line-height:1.7;">
            Stakater stays engaged after delivery. Every platform milestone — more workloads, new team onboarded, new compliance requirement — becomes a deal moment for the channel.
          </p>
        </div>

        <div style="padding:36px; background:white; border-radius:12px; box-shadow:0 8px 30px rgba(0,0,0,0.05);">
          <h3 style="margin-bottom:20px; font-size:22px;">Proof: Multi-Year Partnerships</h3>
          <p style="font-size:18px; color:#374151; line-height:1.7;">
            ATG: 7-year account. Continuous node growth.<br/><br/>
            CSN: Post-delivery → ODF adoption + expansion.<br/><br/>
            Region Skåne: Single cluster → org-wide standard.
          </p>
        </div>

      </div>
      <br/><br/>
      <h2 style="text-align:center;">
        Every year Stakater is engaged, your pipeline <span class="highlight">keeps regenerating.</span>
      </h2>
    </div>
  </section>

  <!-- 7. How to Engage -->
  <section>
    <div class="container">
      <h1 style="text-align:center;">
        How to <span class="highlight">Engage Stakater</span>
      </h1>
      <br/><br/>
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:0; align-items:start; text-align:center;">

        <div style="padding:30px;">
          <div style="font-size:44px; font-weight:800; color:#E00000; margin-bottom:14px;">1</div>
          <h3 style="font-size:19px; margin-bottom:12px;">Identify</h3>
          <p style="font-size:16px; color:#374151;">An account with a lifecycle gap — flat nodes, no portfolio adoption, delivery team gone.</p>
        </div>

        <div style="padding:30px;">
          <div style="font-size:44px; font-weight:800; color:#E00000; margin-bottom:14px;">2</div>
          <h3 style="font-size:19px; margin-bottom:12px;">Introduce</h3>
          <p style="font-size:16px; color:#374151;">Stakater for a platform assessment. We map the expansion opportunity together.</p>
        </div>

        <div style="padding:30px;">
          <div style="font-size:44px; font-weight:800; color:#E00000; margin-bottom:14px;">3</div>
          <h3 style="font-size:19px; margin-bottom:12px;">Co-Design</h3>
          <p style="font-size:16px; color:#374151;">Expansion strategy — workloads, products, clusters. Built jointly with your channel team.</p>
        </div>

        <div style="padding:30px;">
          <div style="font-size:44px; font-weight:800; color:#E00000; margin-bottom:14px;">4</div>
          <h3 style="font-size:19px; margin-bottom:12px;">Register</h3>
          <p style="font-size:16px; color:#374151;">Co-register the expansion deal — nodes, new products, additional clusters.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 8. CTA -->
  <section class="cta">
    <div class="container" style="text-align:center;">
      <h1>
        Let's Build a Joint Pipeline.
      </h1>
      <br/><br/>
      <h2>
        Identify three accounts with a lifecycle gap.<br/>
        We'll show you where the pipeline is.
      </h2>
      <br/><br/><br/>
      <h1 style="font-weight:900;">
        Co-Sell. Co-Grow. Long-Term.
      </h1>
    </div>
  </section>

</Deck>
